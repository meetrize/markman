<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="1">
    <title>Markman</title>
    <welcome>Markman is a block-based Markdown editor built with Rust and GPUI.</welcome>
    <options customize="never" require-scripts="true" rootVolumeOnly="true"/>
    <volume-check>
        <allowed-os-versions>
            <os-version min="10.15"/>
        </allowed-os-versions>
    </volume-check>
    <choices-outline>
        <line choice="default">
            <line choice="Markman"/>
        </line>
    </choices-outline>
    <choice id="default"/>
    <choice id="Markman" title="Install Markman" description="Install Markman to /Applications">
        <pkg-ref id="com.manyougz.Velotype"/>
    </choice>
    <pkg-ref id="com.manyougz.Velotype" version="__VELOTYPE_VERSION__" onConclusion="none">#Markman-component.pkg</pkg-ref>
</installer-gui-script>
