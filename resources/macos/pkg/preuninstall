#!/bin/bash
# Pre-uninstall script for Markman.pkg
# This script runs when the user removes the package

set -e

CLI_LINK="/usr/local/bin/markman"
LEGACY_CLI_LINK="/usr/local/bin/velotype"

echo "==> Markman pre-uninstall script"

for link in "$CLI_LINK" "$LEGACY_CLI_LINK"; do
    if [ -L "$link" ] || [ -e "$link" ]; then
        echo "Removing command-line tool symlink: $link"
        rm -f "$link"
    fi
done

echo "✅ Command-line tool removed"

exit 0
